# Discord (https://discord.com/developers/applications)
# 첫 번째 봇(예: 재미나이·잼민이)
DISCORD_TOKEN_GEMINI=
# 호환: 예전 이름 DISCORD_TOKEN 도 동작함

# 두 번째 봇(예: 클로드) — 비우면 한 봇만 로그인
DISCORD_TOKEN_CLAUDE=

# 봇 이름을 "잼민이"로 보이게 하려면:
#   - Developer Portal에서 Application/Bot 이름을 바꾸거나
#   - 서버에서 봇 우클릭 → 프로필 → 서버 닉네임 을 "잼민이" 로 설정
# 디스코드에서 @잼민이 처럼 부르면 됩니다(멘션은 봇 사용자 ID 기준).

# 채널 ID(쉼표 구분). 세 목록이 모두 비어 있으면 → 모든 채널 허용, 역할은 DEFAULT_MENTION_MODE·문장 분류만 사용.
# 하나라도 넣었으면 → 그 ID만 허용 + 아래 목록으로 역할 고정(봇·모델 프롬프트에 채널 맥락으로 붙음).
# CHAT_CHANNEL_IDS=111111111111111111
# SEARCH_CHANNEL_IDS=222222222222222222
# CODING_CHANNEL_IDS=333333333333333333

# 한 채널 ID가 여러 목록에 동시에 들어갈 때 우선순위(앞이 우선). 비우면 기본 coding,search,chat
CHANNEL_LIST_OVERLAP_PRIORITY=
# 예전 이름: 위가 비어 있을 때만 사용. search → search,coding,chat / 그 외 → coding,search,chat
# OVERLAP_CHANNEL_MODE=coding

# 코딩 역할로 잡힌 채널에서만:
#   auto — 문장 분류(인사는 단발, 파일 작업이면 루프) / loop — 그 채널에선 항상 편집↔검수 루프
CODING_CHANNEL_MODE=auto

# 세 목록이 모두 비었을 때만 쓰는 전역 기본:
#   auto | chat | search | loop
DEFAULT_MENTION_MODE=auto

# 1 이면 서버 설명(guild.description)도 매 프롬프트에 포함(채널 토픽과 별개)
# DISCORD_APPEND_GUILD_DESCRIPTION=1
# DISCORD_GUILD_DESCRIPTION_MAX_CHARS=1200

# 단발 호출 타임아웃(초). 비우면 검색은 CLI 기본(길게) 유지
OPENCLAW_CHAT_TIMEOUT_SEC=240
# OPENCLAW_SEARCH_TIMEOUT_SEC=300

# OpenClaw — 브리지는 HTTP 대신 `openclaw agent` CLI(WebSocket) 사용
# 호스트에서 npm start 할 때:
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_BASE_URL=http://127.0.0.1:18789
# docker-compose 는 OPENCLAW_GATEWAY_URL 을 ws://openclaw-gateway:18789 로 넣음
OPENCLAW_GATEWAY_TOKEN=

OPENCLAW_AGENT_ID=main

# openclaw.json / openclaw models list 와 맞출 것
MODEL_EDITOR=anthropic/claude-opus-4-7
MODEL_REVIEWER=google/gemini-3.1-pro-preview

MAX_ROUNDS=8
MAX_STALE_REVIEWS=2
