{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "sandbox": { "mode": "off" },
      "model": {
        "primary": "google/gemini-3.1-pro-preview"
      },
      "heartbeat": { "every": "" }
    },
    "list": [
      {
        "id": "kchjang",
        "workspace": "/home/node/.openclaw/workspace-kchjang",
        "model": {
          "primary": "anthropic/claude-haiku-4-5-20251001"
        }
      },
      {
        "id": "kchjang-coding",
        "workspace": "/home/node/.openclaw/workspace-kchjang",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6"
        }
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_LONG_RANDOM_TOKEN"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": { "mode": "off", "resetOnExit": false },
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "channelHealthCheckMinutes": 0
  },
  "session": { "dmScope": "per-channel-peer" },
  "tools": { "profile": "coding" },
  "skills": { "install": { "nodeManager": "npm" } },
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "allowBots": "mentions",
      "guilds": {
        "YOUR_SERVER_ID": {
          "tools": {
            "deny": ["image_generate"]
          }
        }
      },
      "inboundWorker": { "runTimeoutMs": 1800000 },
      "accounts": {
        "default": {
          "token": "DISCORD_BOT_TOKEN_JEMJJANG",
          "groupPolicy": "allowlist",
          "ackReaction": "👀"
        },
        "kchjang": {
          "token": "DISCORD_BOT_TOKEN_KLJJANG",
          "groupPolicy": "allowlist",
          "inboundWorker": { "runTimeoutMs": 300000 },
          "ackReaction": "👀"
        }
      }
    }
  },
  "bindings": [
    {
      "match": {
        "channel": "discord",
        "accountId": "kchjang",
        "channelId": "CODING_CHANNEL_ID"
      },
      "agentId": "kchjang-coding"
    },
    {
      "match": {
        "channel": "discord",
        "accountId": "kchjang"
      },
      "agentId": "kchjang"
    }
  ],
  "plugins": {
    "entries": {
      "google": { "enabled": true },
      "anthropic": { "enabled": true }
    }
  },
  "messages": {
    "statusReactions": { "enabled": false }
  }
}
