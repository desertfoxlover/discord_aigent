# Copy to .env and fill in values. Never commit .env.
#
# `docker compose` 를 `openclaw/` 에서 쓰면, 이 파일이 **프로젝트 .env** 로 읽힌다.
# - `openclaw-gateway` 와 (아래) `discord-bridge` 의 `${VAR}` 는 **여기**에서 채워지므로
#   `OPENCLAW_GATEWAY_TOKEN`·`GEMINI_API_KEY` 등은 **이 파일**에 있어야 양쪽이 동시에 맞는다.
# - 토큰을 `discord-bridge/.env` 에만 넣고 여기는 비우면, 게이트웨이는 토큰 없이 뜨고 `unknown agent`/멈춤·401 이 난다.
#
# Pre-built image (no local build). See: https://github.com/openclaw/openclaw/pkgs/container/openclaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Host paths (Windows: use forward slashes or escaped backslashes). Container maps:
#   -> /home/node/.openclaw
#   -> /home/node/.openclaw/workspace
OPENCLAW_CONFIG_DIR=C:/my_AI_agent/openclaw/data/config
OPENCLAW_WORKSPACE_DIR=C:/my_AI_agent/openclaw/data/workspace

# Dashboard / gateway shared secret (generate a long random string)
OPENCLAW_GATEWAY_TOKEN=

# docker-compose 내부에서 discord-bridge → ws://openclaw-gateway:18789 쓸 때 게이트웨이/CLI 보안 검사 통과.
# 프로덕션·공용망이면 wss/터널로 바꾸고 이 값은 비우는 편이 안전합니다.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# Optional: Asia/Seoul etc.
OPENCLAW_TZ=UTC

# Ports on the host
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Bind: lan = reachable from host browser at 127.0.0.1 (see OpenClaw Docker docs)
OPENCLAW_GATEWAY_BIND=lan

# AI providers (passed into the container; add the ones OpenClaw is configured to use)
ANTHROPIC_API_KEY=
# Gemini / Google (OpenClaw: GEMINI_API_KEY or GOOGLE_API_KEY; compose also has GOOGLE_AI_API_KEY)
GOOGLE_AI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
